# ============================================================================
# Slick API — variables de entorno para PRODUCCIÓN (Dokploy)
# Copia estos valores en "Environment" del servicio en Dokploy y rellena
# los secretos. El .env nunca viaja dentro de la imagen Docker.
# ============================================================================

APP_NAME=Slick
APP_ENV=production
# ¡NUNCA true en producción! (expone stack traces y configuración)
APP_DEBUG=false
# URL pública de la API (la que ve el proxy de Next)
APP_URL=https://api.slick.example.com

# Genera una con: php artisan key:generate --show
APP_KEY=

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# Logs a stderr → los recoge Docker/Dokploy
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- Base de datos (MySQL) --------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=slick
DB_USERNAME=
DB_PASSWORD=

# --- Redis (sesión, caché, cola) --------------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# --- Correo ------------------------------------------------------------------
# Configura un mailer real (smtp/resend/ses) para confirmaciones y recordatorios.
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hola@slick.example.com
MAIL_FROM_NAME="${APP_NAME}"

# --- Negocio -----------------------------------------------------------------
AGENDA_TIMEZONE=America/Managua
AGENDA_MIN_LEAD_MINUTES=0
AGENDA_REMINDER_LEAD_HOURS=24

# --- Seguridad ----------------------------------------------------------------
# Rate limits por IP y minuto
RATE_LIMIT_API=60
RATE_LIMIT_AUTH=10
RATE_LIMIT_BOOKING=20
# Mismo valor que BFF_SECRET en el frontend (autentica la cabecera X-Client-IP)
BFF_SECRET=
# Expiración de tokens Sanctum en minutos (7 días)
SANCTUM_EXPIRATION=10080

# --- Google OAuth (Socialite) --------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback del FRONTEND (BFF), registrado igual en Google Cloud Console
GOOGLE_REDIRECT_URI=https://slick.example.com/api/auth/google/callback

# --- Despliegue -----------------------------------------------------------------
# true = ejecuta `php artisan migrate --force` al arrancar el contenedor.
# Con varias réplicas, actívalo solo en una.
RUN_MIGRATIONS=true
